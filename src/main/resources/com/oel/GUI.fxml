<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="804.0" prefWidth="1119.0" styleClass="root-pane" stylesheets="@GUI.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.oel.GUI">
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" prefWidth="1119.0" styleClass="header" stylesheets="@GUI.css" BorderPane.alignment="CENTER">
            <children>
                <Label styleClass="logo" text="ShopEase" />
                <Region HBox.hgrow="ALWAYS" />
                <Label styleClass="cart-icon" text="🛒">
                    <font>
                        <Font size="24.0" />
                    </font>
                </Label>
                <Label fx:id="cartBadgeLabel" styleClass="cart-badge" text="0 items">
                    <HBox.margin>
                        <Insets left="10.0" right="10.0" />
                    </HBox.margin>
                </Label>
                <Label fx:id="headerTotalLabel" styleClass="header-total" text="PKR 0" />
            </children>
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
        </HBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.5" prefHeight="536.0" prefWidth="918.0" styleClass="main-split" stylesheets="@GUI.css" BorderPane.alignment="CENTER">
            <items>
                <AnchorPane styleClass="left-panel">
                    <children>
                        <Label layoutX="20.0" layoutY="15.0" styleClass="panel-title" text="Products" />
                        <TableView fx:id="productTable" layoutX="15.0" layoutY="50.0" prefHeight="580.0" prefWidth="528.0" styleClass="dark-table" AnchorPane.bottomAnchor="140.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="50.0">
                            <columns>
                                <TableColumn fx:id="colProdId" prefWidth="45.0" text="#" />
                                <TableColumn fx:id="colProdName" prefWidth="200.0" text="Name" />
                                <TableColumn fx:id="colProdPrice" prefWidth="150.0" text="Price(PKR)" />
                                <TableColumn fx:id="colProdStock" prefWidth="100.0" text="Stock" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                        <VBox spacing="10.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="15.0">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label styleClass="field-label" text="Quantity: " />
                                        <Spinner fx:id="quantityField" editable="true" prefWidth="80.0" />
                                        <Button mnemonicParsing="false" onAction="#handleAddToCart" styleClass="btn-accent" text="＋  Add to Cart" />
                                    </children>
                                </HBox>
                                <Label fx:id="statusLabel" styleClass="status-text" text="Welcome to ShopEase!" />
                            </children>
                        </VBox>
                    </children>
                </AnchorPane>

                <AnchorPane styleClass="right-panel">
                    <children>
                        <Label layoutX="20.0" layoutY="15.0" styleClass="panel-title" text="Your Cart" />
                        <TableView fx:id="cartTable" layoutX="15.0" layoutY="50.0" prefHeight="500.0" prefWidth="541.0" styleClass="dark-table" AnchorPane.bottomAnchor="180.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="50.0">
                            <columns>
                                <TableColumn fx:id="colCartName" prefWidth="150.0" text="Product" />
                                <TableColumn fx:id="colCartQty" prefWidth="60.0" text="Qty" />
                                <TableColumn fx:id="colCartPrice" prefWidth="110.0" text="Price" />
                                <TableColumn fx:id="colCartSub" prefWidth="120.0" text="Subtotal" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                        <VBox spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Button mnemonicParsing="false" onAction="#handleRemove" styleClass="btn-danger" text="🗑  Remove" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label styleClass="field-label" text="New Qty:" />
                                        <Spinner fx:id="updateQtyField" prefWidth="70.0" />
                                        <Button mnemonicParsing="false" onAction="#handleUpdate" styleClass="btn-secondary" text="↺  Update" />
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="total-row">
                                    <children>
                                        <Label styleClass="total-label" text="Total:" />
                                        <Label fx:id="totalLabel" styleClass="total-amount" text="PKR 0.00" />
                                    </children>
                                </HBox>
                                <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleCheckout" styleClass="btn-checkout" text="Checkout" />
                            </children>
                        </VBox>
                    </children>
                </AnchorPane>
            </items>
        </SplitPane>
    </center>
</BorderPane>